# For local development only (`next dev`). In production on Vercel, set
# these in Project Settings -> Environment Variables instead — and the
# POSTGRES_* / BLOB_READ_WRITE_TOKEN ones get added automatically when you
# link a Postgres database and a Blob store to the project.

PAYTM_MID=
PAYTM_MERCHANT_KEY=
PAYTM_ENV=staging

# A long random secret — must match AGENT_KEY in the print agent's .env on
# your laptop, and whatever you paste into the owner dashboard's "Owner key"
# field. Generate one with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
AGENT_KEY=
